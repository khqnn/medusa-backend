# Existing variables (keep yours)
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
BACKEND_URL=http://localhost:9000
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=my-medusa-store-storefront
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

REDIS_URL=redis://redis:6379
POSTGRES_PASSWORD=S3cret
POSTGRES_USER=citizix_user
POSTGRES_DB=medusa_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://citizix_user:S3cret@postgres:5432/medusa_db

# ---------- File Storage (Images) ----------
USE_S3_FILES=false                     # true = use S3 for images, false = store locally

# If USE_S3_FILES=true, provide S3 credentials for image storage:
# S3_FILE_URL=https://your-bucket.s3.region.amazonaws.com
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_REGION=your_region
# AWS_ENDPOINT_URL=... (optional)
# S3_IMAGE_BUCKET=your-bucket-name

# ---------- Backup ----------
BACKUP_ENABLED=true                    # Set to false to disable all backups
USE_S3_BACKUP=false                    # true = store backups in S3, false = store locally

# S3 settings for backups (only used if USE_S3_BACKUP=true)
S3_BACKUP_BUCKET=
S3_BACKUP_PATH=
# AWS credentials for backup (can reuse the same as above or separate)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_ENDPOINT_URL=

# Retention for local backups (ignored if USE_S3_BACKUP=true)
CLEANUP_AFTER=7d